APP_ENV=local
APP_VERSION=dev
APP_BUILD_SHA=local
APP_BUILD_TIME=unknown
POSTGRES_USER=bd06
POSTGRES_PASSWORD=bd06
POSTGRES_DB=bd06
KAFKA_TOPIC=events.raw
KAFKA_DLQ_TOPIC=events.dlq
INGEST_AUTH_ENABLED=true
INGEST_API_KEYS=local-ingest:local-demo-ingest-key,rotated-ingest:local-demo-ingest-key-2
OPERATOR_API_KEYS=local-ops:local-demo-ops-key,rotated-ops:local-demo-ops-key-2
INGEST_ALLOW_INTERACTIVE_DOCS=true
INGEST_MAX_REQUEST_BYTES=16384
REPLAY_JOB_TIMEOUT_SECONDS=600
LOG_LEVEL=INFO
MINIO_ROOT_USER=bd06admin
MINIO_ROOT_PASSWORD=bd06password
MINIO_BUCKET=events
MINIO_SECURE=false
WORKER_LEASE_SECONDS=30
REPLAY_RUNNER_POLL_SECONDS=2
REPLAY_JOB_LEASE_SECONDS=30
MAINTENANCE_POLL_SECONDS=30
RETENTION_INGEST_LOG_DAYS=30
RETENTION_EVENT_PROCESSING_DAYS=30
RETENTION_DLQ_DAYS=30
RETENTION_REPLAY_JOBS_DAYS=30
RETENTION_AUDIT_LOG_DAYS=90
RETENTION_INGEST_REJECTIONS_DAYS=30
RETENTION_MINIO_RAW_DAYS=30
RETENTION_CLICKHOUSE_DAYS=30
