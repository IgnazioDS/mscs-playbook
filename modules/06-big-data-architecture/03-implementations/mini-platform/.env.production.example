APP_ENV=production
APP_VERSION=1.0.0
APP_BUILD_SHA=replace-with-git-sha
APP_BUILD_TIME=2026-03-14T00:00:00Z
POSTGRES_USER=bd06
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_DB=bd06
KAFKA_TOPIC=events.raw
KAFKA_DLQ_TOPIC=events.dlq
INGEST_AUTH_ENABLED=true
INGEST_API_KEYS=prod-ingest-a:replace-with-strong-ingest-key-a,prod-ingest-b:replace-with-strong-ingest-key-b
OPERATOR_API_KEYS=prod-ops-a:replace-with-strong-operator-key-a,prod-ops-b:replace-with-strong-operator-key-b
INGEST_ALLOW_INTERACTIVE_DOCS=false
INGEST_MAX_REQUEST_BYTES=16384
REPLAY_JOB_TIMEOUT_SECONDS=1800
LOG_LEVEL=INFO
MINIO_ROOT_USER=replace-with-strong-minio-user
MINIO_ROOT_PASSWORD=replace-with-strong-minio-password
MINIO_BUCKET=events
MINIO_SECURE=true
WORKER_LEASE_SECONDS=120
REPLAY_RUNNER_POLL_SECONDS=5
REPLAY_JOB_LEASE_SECONDS=120
MAINTENANCE_POLL_SECONDS=60
RETENTION_INGEST_LOG_DAYS=30
RETENTION_EVENT_PROCESSING_DAYS=30
RETENTION_DLQ_DAYS=30
RETENTION_REPLAY_JOBS_DAYS=30
RETENTION_AUDIT_LOG_DAYS=90
RETENTION_INGEST_REJECTIONS_DAYS=30
RETENTION_MINIO_RAW_DAYS=30
RETENTION_CLICKHOUSE_DAYS=30
