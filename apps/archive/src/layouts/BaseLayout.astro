---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "MSCs Playbook Archive" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style is:global>
      :root {
        color-scheme: light;
        --bg: #f3efe5;
        --bg-accent: #f9f5eb;
        --panel: rgba(255, 252, 245, 0.88);
        --panel-strong: rgba(255, 248, 234, 0.95);
        --line: rgba(53, 48, 39, 0.12);
        --line-strong: rgba(53, 48, 39, 0.22);
        --text: #1f2933;
        --muted: #5b6770;
        --accent: #0f766e;
        --accent-strong: #115e59;
        --accent-soft: rgba(15, 118, 110, 0.12);
        --warning: #b45309;
        --shadow: 0 24px 60px rgba(34, 29, 19, 0.12);
        --radius-xl: 28px;
        --radius-lg: 20px;
        --radius-md: 14px;
        --max: 1180px;
        --body-font: "Avenir Next", "Segoe UI", "Helvetica Neue", sans-serif;
        --display-font: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", "Baskerville", serif;
      }

      * {
        box-sizing: border-box;
      }

      html, body {
        margin: 0;
        padding: 0;
        background:
          radial-gradient(circle at top left, rgba(13, 148, 136, 0.14), transparent 32%),
          radial-gradient(circle at top right, rgba(180, 83, 9, 0.14), transparent 28%),
          linear-gradient(180deg, #f7f3e9 0%, #f1eadc 100%);
        color: var(--text);
        font-family: var(--body-font);
      }

      body {
        min-height: 100vh;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      p, li {
        color: var(--muted);
        line-height: 1.65;
      }

      h1, h2, h3, h4 {
        color: var(--text);
        font-family: var(--display-font);
        line-height: 1.1;
        letter-spacing: -0.02em;
      }

      code, pre {
        font-family: "SFMono-Regular", "Menlo", "Consolas", monospace;
      }

      .shell {
        width: min(var(--max), calc(100vw - 2rem));
        margin: 0 auto;
        padding: 1.1rem 0 3rem;
      }

      .masthead {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: 1rem 0 1.4rem;
      }

      .brand {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
      }

      .brand-kicker {
        font-size: 0.72rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--accent-strong);
      }

      .brand-title {
        font-size: 1.25rem;
        font-weight: 700;
      }

      .nav {
        display: flex;
        flex-wrap: wrap;
        gap: 0.7rem;
      }

      .nav a {
        padding: 0.6rem 0.9rem;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.45);
        color: var(--muted);
        transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
      }

      .nav a:hover {
        transform: translateY(-1px);
        border-color: var(--line-strong);
        background: rgba(255, 255, 255, 0.75);
      }

      .panel {
        border: 1px solid var(--line);
        border-radius: var(--radius-xl);
        background: var(--panel);
        box-shadow: var(--shadow);
        backdrop-filter: blur(14px);
      }

      .panel-tight {
        border-radius: var(--radius-lg);
        padding: 1.2rem;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.35rem 0.65rem;
        border-radius: 999px;
        font-size: 0.72rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        background: var(--accent-soft);
        color: var(--accent-strong);
      }

      .grid {
        display: grid;
        gap: 1rem;
      }

      .badge-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
      }

      .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.35rem 0.65rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.74);
        border: 1px solid var(--line);
        color: var(--muted);
        font-size: 0.8rem;
      }

      .card {
        border-radius: var(--radius-lg);
        border: 1px solid var(--line);
        background: var(--panel-strong);
        padding: 1.2rem;
      }

      .card h3, .card h2 {
        margin: 0;
      }

      .section-head {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 1rem;
        margin-bottom: 1rem;
      }

      .section-head p {
        margin: 0.35rem 0 0;
      }

      .muted {
        color: var(--muted);
      }

      .cta {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.8rem 1.1rem;
        border-radius: 999px;
        background: linear-gradient(135deg, var(--accent) 0%, #155e75 100%);
        color: white;
        font-weight: 700;
        box-shadow: 0 14px 28px rgba(17, 94, 89, 0.24);
      }

      .meta-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.8rem;
        color: var(--muted);
        font-size: 0.92rem;
      }

      .markdown {
        display: grid;
        gap: 1rem;
      }

      .markdown p,
      .markdown ul,
      .markdown ol,
      .markdown table,
      .markdown pre,
      .markdown blockquote {
        margin: 0;
      }

      .markdown pre {
        padding: 1rem;
        background: #1f2933;
        color: #f8fafc;
        overflow-x: auto;
        border-radius: var(--radius-md);
      }

      .markdown code:not(pre code) {
        padding: 0.16rem 0.35rem;
        border-radius: 0.35rem;
        background: rgba(15, 118, 110, 0.08);
        color: var(--accent-strong);
      }

      .markdown table {
        width: 100%;
        border-collapse: collapse;
      }

      .markdown th,
      .markdown td {
        padding: 0.8rem;
        border-bottom: 1px solid var(--line);
        text-align: left;
      }

      .markdown blockquote {
        padding-left: 1rem;
        border-left: 4px solid rgba(15, 118, 110, 0.3);
      }

      .markdown img {
        max-width: 100%;
        border-radius: var(--radius-md);
      }

      .breadcrumbs {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
        font-size: 0.86rem;
        color: var(--muted);
      }

      .breadcrumbs span:last-child {
        color: var(--text);
      }

      .toc {
        position: sticky;
        top: 1rem;
      }

      @media (max-width: 900px) {
        .masthead {
          flex-direction: column;
          align-items: flex-start;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <header class="masthead">
        <a href="/" class="brand">
          <span class="brand-kicker">Knowledge Archive</span>
          <span class="brand-title">MSCS Playbook Archive</span>
        </a>
        <nav class="nav">
          <a href="/">Home</a>
          <a href="/browse">Browse</a>
          <a href="/modules">Modules</a>
          <a href="/projects">Projects</a>
          <a href="/tracks">Tracks</a>
        </nav>
      </header>
      <slot />
    </div>
  </body>
</html>
