---
import BaseLayout from "../layouts/BaseLayout.astro";
import { archiveItems, searchIndex } from "../lib/archive";

const records = searchIndex.documents.map((doc) => {
  const item = archiveItems.find((candidate) => candidate.id === doc.id);
  return {
    ...doc,
    status: item?.status ?? "",
    format: item?.format ?? "",
    module_title: item?.module?.title ?? "",
    track_titles: item?.tracks ?? []
  };
});
---

<BaseLayout title="Browse | MSCS Playbook Archive" description="Search and filter the MSCs Playbook archive.">
  <section class="panel panel-tight">
    <div class="section-head">
      <div>
        <div class="eyebrow">Browse</div>
        <h1 style="font-size: 2.8rem; margin: 0.45rem 0 0;">Search the archive</h1>
        <p>Full-text search is backed by the generated search index, then refined with collection, content-type, module, and track filters.</p>
      </div>
      <span class="badge">{records.length} indexed records</span>
    </div>

    <div class="grid archive-filter-grid" style="grid-template-columns: repeat(5, minmax(0, 1fr)); margin-bottom: 1rem;">
      <label class="card" style="padding: 0.9rem;">
        <div class="eyebrow">Query</div>
        <input id="query" type="search" placeholder="Try 'retrieval', 'NAT', or 'policy gradient'" autocomplete="off" style="width: 100%; margin-top: 0.7rem; border: none; background: transparent; font: inherit; color: var(--text);" />
      </label>
      <label class="card" style="padding: 0.9rem;">
        <div class="eyebrow">Collection</div>
        <select id="collection" style="width: 100%; margin-top: 0.7rem; border: none; background: transparent; font: inherit; color: var(--text);">
          <option value="">All collections</option>
          {searchIndex.filters.collections.map((filter) => <option value={filter.key}>{filter.label}</option>)}
        </select>
      </label>
      <label class="card" style="padding: 0.9rem;">
        <div class="eyebrow">Type</div>
        <select id="content-type" style="width: 100%; margin-top: 0.7rem; border: none; background: transparent; font: inherit; color: var(--text);">
          <option value="">All content types</option>
          {searchIndex.filters.content_types.map((filter) => <option value={filter.key}>{filter.label}</option>)}
        </select>
      </label>
      <label class="card" style="padding: 0.9rem;">
        <div class="eyebrow">Module</div>
        <select id="module" style="width: 100%; margin-top: 0.7rem; border: none; background: transparent; font: inherit; color: var(--text);">
          <option value="">All modules</option>
          {searchIndex.filters.modules.map((filter) => <option value={filter.key}>{filter.label}</option>)}
        </select>
      </label>
      <label class="card" style="padding: 0.9rem;">
        <div class="eyebrow">Track</div>
        <select id="track" style="width: 100%; margin-top: 0.7rem; border: none; background: transparent; font: inherit; color: var(--text);">
          <option value="">All tracks</option>
          {searchIndex.filters.tracks.map((filter) => <option value={filter.key}>{filter.label}</option>)}
        </select>
      </label>
    </div>

    <div class="meta-list" style="margin-bottom: 1rem;">
      <span id="results-count" aria-live="polite">Showing {records.length} results</span>
      <span>Client-side ranking prefers title and summary matches, then keywords and body text.</span>
    </div>

    <div id="results" class="grid" style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));"></div>
  </section>

  <script id="search-records" type="application/json" set:html={JSON.stringify(records)}></script>
  <script>
    import { initBrowsePage } from "../scripts/browseSearch.js";
    initBrowsePage();
  </script>
</BaseLayout>
