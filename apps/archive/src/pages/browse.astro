---
import BaseLayout from "../layouts/BaseLayout.astro";
import { searchIndex } from "../lib/archive";
---

<BaseLayout title="Browse | MSCS Playbook Archive" description="Search and filter the MSCs Playbook archive.">
  <section class="panel panel-tight">
    <div class="section-head">
      <div>
        <div class="eyebrow">Browse</div>
        <h1 style="font-size: 2.8rem; margin: 0.45rem 0 0;">Search the archive</h1>
        <p>Full-text search is backed by the generated search index, then refined with collection, content-type, module, and track filters.</p>
      </div>
      <span class="badge">{searchIndex.documents.length} indexed records</span>
    </div>

    <div class="grid archive-filter-grid" style="grid-template-columns: repeat(5, minmax(0, 1fr)); margin-bottom: 1rem;">
      <label class="card" style="padding: 0.9rem;">
        <div class="eyebrow">Query</div>
        <input id="query" type="search" placeholder="Try 'retrieval', 'NAT', or 'policy gradient'" autocomplete="off" style="width: 100%; margin-top: 0.7rem; border: none; background: transparent; font: inherit; color: var(--text);" />
      </label>
      <label class="card" style="padding: 0.9rem;">
        <div class="eyebrow">Collection</div>
        <div style="max-height: 120px; overflow-y: auto; margin-top: 0.7rem; display: flex; flex-direction: column; gap: 0.4rem;">
          {searchIndex.filters.collections.map((filter) => (
            <label style="font-size: 0.9rem; cursor: pointer; display: flex; align-items: center; gap: 0.4rem;">
              <input type="checkbox" name="collection" value={filter.key} />
              <span>{filter.label}</span>
            </label>
          ))}
        </div>
      </label>
      <label class="card" style="padding: 0.9rem;">
        <div class="eyebrow">Type</div>
        <div style="max-height: 120px; overflow-y: auto; margin-top: 0.7rem; display: flex; flex-direction: column; gap: 0.4rem;">
          {searchIndex.filters.content_types.map((filter) => (
            <label style="font-size: 0.9rem; cursor: pointer; display: flex; align-items: center; gap: 0.4rem;">
              <input type="checkbox" name="content_type" value={filter.key} />
              <span>{filter.label}</span>
            </label>
          ))}
        </div>
      </label>
      <label class="card" style="padding: 0.9rem;">
        <div class="eyebrow">Module</div>
        <div style="max-height: 120px; overflow-y: auto; margin-top: 0.7rem; display: flex; flex-direction: column; gap: 0.4rem;">
          {searchIndex.filters.modules.map((filter) => (
            <label style="font-size: 0.9rem; cursor: pointer; display: flex; align-items: center; gap: 0.4rem;">
              <input type="checkbox" name="module" value={filter.key} />
              <span>{filter.label}</span>
            </label>
          ))}
        </div>
      </label>
      <label class="card" style="padding: 0.9rem;">
        <div class="eyebrow">Track</div>
        <div style="max-height: 120px; overflow-y: auto; margin-top: 0.7rem; display: flex; flex-direction: column; gap: 0.4rem;">
          {searchIndex.filters.tracks.map((filter) => (
            <label style="font-size: 0.9rem; cursor: pointer; display: flex; align-items: center; gap: 0.4rem;">
              <input type="checkbox" name="track" value={filter.key} />
              <span>{filter.label}</span>
            </label>
          ))}
        </div>
      </label>
    </div>

    <div class="meta-list" style="margin-bottom: 1rem;">
      <span id="results-count" aria-live="polite">Loading archive index over the network...</span>
      <span>Client-side ranking prefers title and summary matches, then keywords and body text.</span>
    </div>

    <div id="results" class="grid" style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));"></div>
  </section>


  <script>
    import { initBrowsePage } from "../scripts/browseSearch.js";
    initBrowsePage();
  </script>
</BaseLayout>
