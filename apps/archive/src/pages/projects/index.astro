---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ItemCard from "../../components/ItemCard.astro";
import { itemsById, moduleCatalogByKey, projectCatalog } from "../../lib/archive";

const items = projectCatalog
  .map((entry) => ({ entry, item: itemsById.get(entry.id) }))
  .filter((value): value is { entry: (typeof projectCatalog)[number]; item: NonNullable<ReturnType<typeof itemsById.get>> } => Boolean(value.item));
---

<BaseLayout title="Projects | MSCS Playbook Archive" description="Project hubs for the MSCs Playbook archive.">
  <section class="panel panel-tight">
    <div class="section-head">
      <div>
        <div class="eyebrow">Projects</div>
        <h1 style="font-size: 2.8rem; margin: 0.45rem 0 0;">Portfolio briefs as archive objects</h1>
        <p>Project pages now participate in archive retrieval instead of living as isolated README files.</p>
      </div>
      <a class="badge" href="/browse?collection=projects">Browse project documents</a>
    </div>
    <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));">
      {items.map(({ entry, item }) => (
        <div class="card">
          <ItemCard item={item} />
          <div class="badge-row" style="margin-top: 0.8rem;">
            {(entry.module_ids ?? []).map((moduleId) => {
              const moduleItem = itemsById.get(moduleId);
              return moduleItem ? <a class="badge" href={moduleItem.url}>{moduleItem.title}</a> : null;
            })}
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
