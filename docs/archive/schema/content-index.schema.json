{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Knowledge Archive Content Index",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "source_roots",
    "counts",
    "catalog",
    "items"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "source_roots": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "counts": {
      "type": "object"
    },
    "catalog": {
      "type": "object"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "path",
          "url",
          "slug",
          "collection",
          "content_type",
          "summary",
          "format",
          "status",
          "tags"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "collection": {
            "type": "string"
          },
          "content_type": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "format": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
